@namespace Monitor.App.Components.Layout
@inject StatusService StatusService
@inject Services.TunnelService TunnelService
@inject Infrastructure.Config.AppSettings AppSettings
@implements IDisposable

<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-mark"><Icon Name="monitor" Size="20" /></div>
        <div>
            <div class="brand-title">Monitor</div>
            <div class="brand-subtitle">公用机管理</div>
        </div>
    </div>

    <nav class="sidebar-nav">
        @foreach (var item in _navItems)
        {
            <NavLink href="@item.Href" class="sidebar-item" ActiveClass="active"
                     Match="@item.Match" title="@item.Label" aria-label="@item.Label">
                <span class="sidebar-icon"><Icon Name="@item.Icon" Size="18" /></span>
                <span class="nav-label">@item.Label</span>
            </NavLink>
        }
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-health">
            <div class="sidebar-health-main">
                <span class="status-dot @_statusClass"></span>
                <span>@_statusText</span>
            </div>
            <div class="sidebar-health-grid">
                <span>&#20844;&#32593;</span><strong class="@_publicClass">@_publicText</strong>
                <span>&#30331;&#35760;&#30721;</span><strong class="@_registerClass">@_registerText</strong>
                @if (_isRemote && !string.IsNullOrWhiteSpace(_remoteType))
                {
                    <span>远程</span><strong class="danger">@_remoteType</strong>
                }
            </div>
        </div>
        <div class="sidebar-footer-meta">
            <span>v3.0.0</span>
            <span>@_timeDisplay</span>
        </div>
    </div>
</aside>

@code {
    private string _statusClass = "idle";
    private string _statusText = "空闲";
    private string? _statusNote;
    private bool _isRemote;
    private string? _remoteType;
    private string _publicText = "\u672a\u8fde\u63a5";
    private string _publicClass = "warning";
    private string _registerText = "\u7f3a\u5931";
    private string _registerClass = "warning";
    private string _timeDisplay = "";
    private Timer? _timer;

    private readonly (string Href, string Label, string Icon, NavLinkMatch Match)[] _navItems =
    {
        ("/", "控制台", "dashboard", NavLinkMatch.All),
        ("/timer", "计时", "timer", NavLinkMatch.Prefix),
        ("/history", "历史", "history", NavLinkMatch.Prefix),
        ("/statistics", "统计", "chart", NavLinkMatch.Prefix),
        ("/reservation", "预约", "calendar", NavLinkMatch.Prefix),
        ("/settings", "设置", "settings", NavLinkMatch.Prefix),
    };

    protected override void OnInitialized()
    {
        RefreshStatus();
        _timer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                RefreshStatus();
                StateHasChanged();
            });
        }, null, 3000, 3000);
    }

    private void RefreshStatus()
    {
        var status = StatusService.GetSidebarStatus();
        var tunnel = TunnelService.GetStatus();
        _isRemote = status.IsRemote;
        _remoteType = status.RemoteType;

        if (status.Status == "error")
        {
            _statusClass = "error";
            _statusText = "检测异常";
            _statusNote = status.ErrorMessage;
        }
        else if (status.Status == "unknown")
        {
            _statusClass = "unknown";
            _statusText = "状态未知";
            _statusNote = "远程检测未开启";
        }
        else if (_isRemote)
        {
            _statusClass = "remote_controlled";
            _statusText = "远程占用";
        }
        else if (status.IsTiming)
        {
            _statusClass = "in_use";
            _statusText = $"使用中 · {status.CurrentUser}";
        }
        else
        {
            _statusClass = "idle";
            _statusText = "空闲";
            _statusNote = null;
        }

        if (tunnel.Running && !string.IsNullOrWhiteSpace(tunnel.PublicUrl))
        {
            _publicText = "\u5df2\u8fde\u63a5";
            _publicClass = "ok";
        }
        else if (!string.IsNullOrWhiteSpace(tunnel.Error))
        {
            _publicText = "\u5f02\u5e38";
            _publicClass = "danger";
        }
        else
        {
            _publicText = "\u672a\u8fde\u63a5";
            _publicClass = "warning";
        }

        if (string.IsNullOrWhiteSpace(AppSettings.OperatorRegistrationKey))
        {
            _registerText = "\u7f3a\u5931";
            _registerClass = "warning";
        }
        else
        {
            _registerText = "\u6b63\u5e38";
            _registerClass = "ok";
        }

        _timeDisplay = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
    }

    public void Dispose() => _timer?.Dispose();
}
