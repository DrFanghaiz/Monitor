@page "/"
@namespace Monitor.App.Components.Pages
@inject StatusService StatusService
@inject Services.TimerService TimerService
@inject ReservationService ReservationService
@inject RemoteMonitorService RemoteMonitorService
@inject IRemoteSessionRepository RemoteSessionRepo
@implements IDisposable

<PageTitle>控制台 · Monitor</PageTitle>

<div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">
                <span class="page-title-icon"><Icon Name="dashboard" Size="20" /></span>
                控制台
            </h1>
            <p class="page-subtitle">@(_status?.Timestamp ?? DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"))</p>
        </div>
        @if (_status != null)
        {
            <span class="status-badge @GetStatusClass(_status.ComputerStatus)">
                <span class="status-dot @GetStatusClass(_status.ComputerStatus)"></span>
                @GetStatusText(_status.ComputerStatus)
            </span>
        }
    </header>

    @if (_status != null)
    {
        <section class="card-elevated hero-card">
            <div>
                <div class="machine-row">
                    <div class="machine-icon"><Icon Name="monitor" Size="22" /></div>
                    <div>
                        <div class="machine-title">公用计算机</div>
                        <div class="machine-subtitle">
                            @(TimerService.IsRunning ? $"当前使用者: {TimerService.CurrentUserName}" : "设备空闲，可以开始计时")
                        </div>
                    </div>
                </div>

                @if (!TimerService.IsRunning)
                {
                    <div class="quick-start">
                        <input class="input" @bind="_startName" @bind:event="oninput" @onkeydown="HandleStartKeyDown" placeholder="输入姓名快速开始" aria-label="使用者姓名" />
                        <button class="btn btn-primary" @onclick="StartTimer" disabled="@string.IsNullOrWhiteSpace(_startName)">
                            <Icon Name="play" Size="15" />
                            开始
                        </button>
                    </div>
                }
                else
                {
                    <div class="quick-start">
                        <button class="btn btn-danger" @onclick="StopTimer">
                            <Icon Name="stop" Size="15" />
                            停止计时
                        </button>
                        <span class="message" style="margin-top:0;">正在记录 @TimerService.CurrentUserName 的使用时长</span>
                    </div>
                }

                @if (_startMsg != null)
                {
                    <div class="message">@_startMsg</div>
                }
            </div>

            <div class="current-session">
                <div class="session-label">当前会话</div>
                <div class="session-value">@_status.LocalUse.ElapsedFormatted</div>
                <div class="row-subtitle">@(_status.LocalUse.CurrentUser ?? "未开始")</div>
            </div>
        </section>

        <section class="metric-grid">
            <div class="card">
                <div class="metric-head">
                    <div class="metric-label">今日使用记录</div>
                    <span class="metric-icon"><Icon Name="history" Size="16" /></span>
                </div>
                <div class="metric-value">@_status.TodayRecords.Count</div>
                <div class="metric-note">条会话</div>
            </div>
            <div class="card">
                <div class="metric-head">
                    <div class="metric-label">今日预约</div>
                    <span class="metric-icon"><Icon Name="calendar" Size="16" /></span>
                </div>
                <div class="metric-value">@_status.TodayReservations.Count</div>
                <div class="metric-note">项预约</div>
            </div>
            <div class="card">
                <div class="metric-head">
                    <div class="metric-label">远程控制</div>
                    <span class="metric-icon"><Icon Name="shield" Size="16" /></span>
                </div>
                <div class="metric-value" style="font-size:22px;color:@GetRemoteColor();">
                    @GetRemoteStatusText()
                </div>
                <div class="metric-note">
                    @GetRemoteNoteText()
                </div>
                @if (_status.RemoteControl.IsRemote && string.IsNullOrEmpty(_status.RemoteControl.OperatorName))
                {
                    <div style="margin-top:12px;display:flex;gap:8px;align-items:center;">
                        <input class="input" @bind="_operatorInput" placeholder="登记操作人姓名"
                               style="width:160px;height:32px;font-size:13px;" />
                        <button class="btn btn-primary" style="font-size:12px;padding:6px 14px;"
                                @onclick="RegisterOperator" disabled="@(string.IsNullOrWhiteSpace(_operatorInput))">
                            登记
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_operatorMsg))
                    {
                        <div style="margin-top:6px;font-size:12px;color:var(--text-secondary);">@_operatorMsg</div>
                    }
                }
                else if (_status.RemoteControl.IsRemote && !string.IsNullOrEmpty(_status.RemoteControl.OperatorName))
                {
                    <div style="margin-top:10px;font-size:13px;">
                        操作人：<strong>@_status.RemoteControl.OperatorName</strong>
                        <button class="btn btn-ghost" style="font-size:11px;padding:3px 10px;margin-left:8px;"
                                @onclick="ShowModifyOperator">修改</button>
                    </div>
                    @if (_showOperatorModify)
                    {
                        <div style="margin-top:8px;display:flex;gap:8px;align-items:center;">
                            <input class="input" @bind="_operatorInput" placeholder="新姓名"
                                   style="width:160px;height:32px;font-size:13px;" />
                            <button class="btn btn-primary" style="font-size:12px;padding:6px 14px;"
                                    @onclick="RegisterOperator" disabled="@(string.IsNullOrWhiteSpace(_operatorInput))">
                                确认
                            </button>
                            <button class="btn btn-ghost" style="font-size:12px;padding:6px 14px;"
                                    @onclick="CancelModifyOperator">取消</button>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_operatorMsg))
                    {
                        <div style="margin-top:6px;font-size:12px;color:var(--text-secondary);">@_operatorMsg</div>
                    }
                }
            </div>
        </section>

        <section class="split-grid">
            <div class="card">
                <h2 class="section-title"><Icon Name="history" Size="16" />今日活动</h2>
                @if (!_status.TodayRecords.Any())
                {
                    <div class="empty-state">今日暂无使用记录</div>
                }
                else
                {
                    <div class="data-list">
                        @foreach (var r in _status.TodayRecords.Take(10))
                        {
                            <div class="data-row">
                                <div class="row-main">
                                    <div class="avatar">@GetInitial(r.UserName)</div>
                                    <div>
                                        <div class="row-title">@r.UserName</div>
                                        <div class="row-subtitle">@GetTimeRange(r.StartTime, r.EndTime)</div>
                                    </div>
                                </div>
                                <div class="row-meta">@Services.TimerService.FormatDuration(r.DurationSeconds)</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card">
                <h2 class="section-title"><Icon Name="calendar" Size="16" />今日预约</h2>
                @if (!_status.TodayReservations.Any())
                {
                    <div class="empty-state">今日暂无预约</div>
                }
                else
                {
                    <div class="data-list">
                        @foreach (var r in _status.TodayReservations.Take(10))
                        {
                            <div class="data-row">
                                <div class="row-main">
                                    <div class="avatar">@GetInitial(r.UserName)</div>
                                    <div>
                                        <div class="row-title">@r.UserName</div>
                                        <div class="row-subtitle">@r.Date</div>
                                    </div>
                                </div>
                                <span class="badge badge-warning">@($"{r.StartHour:D2}:00 - {r.EndHour:D2}:00")</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>

        <section style="margin-top:16px;">
            <div class="card">
                <h2 class="section-title"><Icon Name="shield" Size="16" />最近远程会话</h2>
                @if (!_remoteSessions.Any())
                {
                    <div class="empty-state">暂无远程会话记录</div>
                }
                else
                {
                    <div class="data-list">
                        @foreach (var s in _remoteSessions.Take(10))
                        {
                            <div class="data-row">
                                <div class="row-main">
                                    <div>
                                        <div class="row-title">
                                            @s.RemoteType
                                            @if (s.IsActive)
                                            {
                                                <span class="badge badge-danger" style="margin-left:6px;">活跃</span>
                                            }
                                        </div>
                                        <div class="row-subtitle">
                                            操作人: @(s.OperatorName ?? "未登记") · @s.StartTime
                                            @if (s.EndTime != null) { <span> → @s.EndTime</span> }
                                        </div>
                                    </div>
                                </div>
                                <div class="row-meta">@Services.TimerService.FormatDuration(s.DurationSeconds)</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    }
</div>

@code {
    private AppStatus? _status;
    private string _startName = "";
    private string? _startMsg;
    private string _operatorInput = "";
    private string? _operatorMsg;
    private bool _showOperatorModify;
    private List<Monitor.App.Models.RemoteSession> _remoteSessions = new();
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        _status = StatusService.GetFullStatus();
        _remoteSessions = RemoteSessionRepo.GetRecentRemoteSessions(20);
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                _status = StatusService.GetFullStatus();
                _remoteSessions = RemoteSessionRepo.GetRecentRemoteSessions(20);
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private void StartTimer()
    {
        if (TimerService.StartTimer(_startName))
        {
            _startMsg = "计时已开始";
            _startName = "";
            _status = StatusService.GetFullStatus();
        }
        else
        {
            _startMsg = "请输入姓名";
        }
    }

    private void HandleStartKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            StartTimer();
        }
    }

    private void StopTimer()
    {
        TimerService.StopTimer();
        _startMsg = "计时已停止";
        _status = StatusService.GetFullStatus();
    }

    private string GetStatusClass(string status) => status switch
    {
        "error" => "error",
        "unknown" => "unknown",
        "remote_controlled" => "remote_controlled",
        "in_use" => "in_use",
        _ => "idle"
    };

    private string GetStatusText(string status) => status switch
    {
        "error" => "检测异常",
        "unknown" => "状态未知",
        "remote_controlled" => "疑似远程占用",
        "in_use" => "使用中",
        _ => "空闲"
    };

    private string GetRemoteColor()
    {
        var rc = _status?.RemoteControl;
        if (rc == null) return "var(--text-muted)";
        if (rc.IsRemote) return "var(--danger)";
        if (rc.Status == "unknown") return "var(--warning)";
        if (rc.Status == "error") return "var(--danger)";
        return "var(--success)";
    }

    private string GetRemoteStatusText()
    {
        var rc = _status?.RemoteControl;
        if (rc == null) return "未知";
        if (rc.IsRemote) return "疑似远程占用";
        if (rc.Status == "unknown") return "未开启";
        if (rc.Status == "error") return "异常";
        return "未检测到远程占用";
    }

    private string GetRemoteNoteText()
    {
        var rc = _status?.RemoteControl;
        if (rc == null) return "无法获取远程状态";
        if (rc.IsRemote)
        {
            var parts = new List<string>();
            if (!string.IsNullOrEmpty(rc.Message))
                parts.Add(rc.Message);
            else
            {
                var tool = rc.RemoteType ?? "未知工具";
                parts.Add($"工具: {tool} · 已持续 {rc.ElapsedFormatted}");
                if (!string.IsNullOrEmpty(rc.Source))
                    parts.Add($"来源: {rc.Source}");
                if (!string.IsNullOrEmpty(rc.Confidence))
                    parts.Add($"置信度: {rc.Confidence}");
            }
            if (rc.MatchedSignals?.Count > 0)
                parts.Add($"信号: {string.Join(", ", rc.MatchedSignals)}");
            return string.Join(" · ", parts);
        }
        if (!string.IsNullOrEmpty(rc.Message))
            return rc.Message;
        if (rc.Status == "unknown") return rc.ErrorMessage ?? "远程检测未开启或状态未知";
        if (rc.Status == "error") return rc.ErrorMessage ?? "远程检测异常";
        return "未检测到远程占用";
    }

    private static string GetInitial(string value)
        => string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString();

    private static string GetTimeRange(string start, string end)
        => $"{FormatTime(start)} - {FormatTime(end)}";

    private static string FormatTime(string value)
        => value.Length >= 16 ? value.Substring(11, 5) : value;

    private void RegisterOperator()
    {
        if (string.IsNullOrWhiteSpace(_operatorInput)) return;
        if (RemoteMonitorService.TrySetOperatorName(_operatorInput.Trim(), out var error))
        {
            _operatorMsg = "操作人已登记";
            _operatorInput = "";
            _showOperatorModify = false;
            _status = StatusService.GetFullStatus();
        }
        else
        {
            _operatorMsg = error;
        }
    }

    private void ShowModifyOperator()
    {
        _showOperatorModify = true;
        _operatorInput = _status?.RemoteControl.OperatorName ?? "";
    }

    private void CancelModifyOperator()
    {
        _showOperatorModify = false;
        _operatorInput = "";
        _operatorMsg = "";
    }

    public void Dispose() => _timer?.Dispose();
}
