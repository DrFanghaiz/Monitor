@page "/"
@namespace Monitor.App.Components.Pages
@inject StatusService StatusService
@inject Services.TimerService TimerService
@inject RemoteMonitorService RemoteMonitorService
@inject Services.TunnelService TunnelService
@inject IRemoteSessionRepository RemoteSessionRepo
@implements IDisposable

<PageTitle>控制台 · Monitor</PageTitle>

<div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">控制台</h1>
            <p class="page-subtitle">@(_status?.Timestamp ?? DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"))</p>
        </div>
        @if (_status != null)
        {
            <span class="status-badge @GetStatusClass(_status.ComputerStatus)">
                <span class="status-dot @GetStatusClass(_status.ComputerStatus)"></span>
                @GetStatusText(_status.ComputerStatus)
            </span>
        }
    </header>

    @if (_status != null)
    {
        var rc = _status.RemoteControl;
        var isRemote = rc.IsRemote;
        var cs = _status.ComputerStatus;
        var display = GetRemoteDisplay(cs, rc);
        var ts = _tunnelState;

        @* ===== PRIMARY STATUS ===== *@
        <div class="card card-elevated dashboard-status @display.StatusClass">
            <div class="status-top">
                <div class="status-hero">
                    <div class="primary-dot"></div>
                    <div>
                        <div class="primary-label">@display.Label</div>
                        <div class="primary-tip">@display.Tip</div>
                    </div>
                </div>

                <div class="status-facts">
                    <div class="info-item"><div class="info-label">远程工具</div><div class="info-value">@(rc.RemoteType ?? "—")</div></div>
                    <div class="info-item"><div class="info-label">操作人</div><div class="info-value">@(isRemote ? (rc.OperatorName ?? "未登记") : "—")</div></div>
                    <div class="info-item"><div class="info-label">开始时间</div><div class="info-value">@(isRemote && rc.StartTime != null ? rc.StartTime : "—")</div></div>
                    <div class="info-item"><div class="info-label">已占用时长</div><div class="info-value">@(isRemote ? rc.ElapsedFormatted : "—")</div></div>
                </div>
            </div>

            <div class="status-bottom">
                <div class="public-line">
                    @if (!string.IsNullOrEmpty(ts.PublicUrl))
                    {
                        <span class="public-status-label">公网</span>
                        <a class="public-host" href="@($"{ts.PublicUrl}/status")">@GetHostText(ts.PublicUrl)</a>
                    }
                    else if (!string.IsNullOrEmpty(ts.Error))
                    {
                        <span class="public-status-label warning">公网</span>
                        <span class="public-host muted">@ShortTunnelError(ts.Error)</span>
                    }
                    else if (ts.Running)
                    {
                        <span class="public-status-label">公网</span>
                        <span class="public-host muted">连接中</span>
                    }
                    else
                    {
                        <span class="public-status-label muted">公网</span>
                        <span class="public-host muted">未启动</span>
                    }
                </div>

                <div class="operator-row">
                    @if (isRemote && string.IsNullOrEmpty(rc.OperatorName))
                    {
                        <input class="input" @bind="_operatorInput" placeholder="登记操作人姓名" />
                        <button class="btn btn-primary btn-sm" @onclick="RegisterOperator"
                                disabled="@(string.IsNullOrWhiteSpace(_operatorInput))">登记</button>
                    }
                    else if (isRemote && !string.IsNullOrEmpty(rc.OperatorName))
                    {
                        <span class="operator-current">操作人：<strong>@rc.OperatorName</strong></span>
                        @if (!_showOperatorModify)
                        {
                            <button class="btn btn-ghost btn-sm" @onclick="ShowModifyOperator">修改</button>
                        }
                        else
                        {
                            <input class="input" @bind="_operatorInput" placeholder="新姓名" />
                            <button class="btn btn-primary btn-sm" @onclick="RegisterOperator"
                                    disabled="@(string.IsNullOrWhiteSpace(_operatorInput))">确认</button>
                            <button class="btn btn-ghost btn-sm" @onclick="CancelModifyOperator">取消</button>
                        }
                    }
                    @if (!string.IsNullOrEmpty(_operatorMsg))
                    {
                        <span class="primary-msg">@_operatorMsg</span>
                    }
                </div>
            </div>
        </div>

        @* ===== 三列辅助区 ===== *@
        <div class="dashboard-bottom">
            <div class="card">
                <h2 class="section-title">本机计时</h2>
                @if (!TimerService.IsRunning)
                {
                    <div class="quick-timer-row">
                        <input class="input quick-timer-input" @bind="_startName" @bind:event="oninput"
                               @onkeydown="HandleStartKeyDown" placeholder="输入姓名快速开始" />
                        <button class="btn btn-primary btn-sm quick-timer-button" @onclick="StartTimer"
                                disabled="@string.IsNullOrWhiteSpace(_startName)">开始</button>
                    </div>
                }
                else
                {
                    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                        <span class="timer-display" style="font-size:28px">@_status.LocalUse.ElapsedFormatted</span>
                        <span style="font-size:13px;color:var(--text-secondary);margin-right:auto">@(_status.LocalUse.CurrentUser ?? "")</span>
                        <button class="btn btn-danger btn-sm" @onclick="StopTimer">停止</button>
                    </div>
                }
                @if (_startMsg != null)
                { <div class="message">@_startMsg</div> }
            </div>

            <div class="card">
                <h2 class="section-title">今日活动</h2>
                @if (!_status.TodayRecords.Any())
                { <div class="empty-state">今日暂无使用记录</div> }
                else
                {
                    <div class="data-list">
                        @foreach (var r in _status.TodayRecords.Take(5))
                        {
                            <div class="data-row">
                                <div class="row-main">
                                    <div class="avatar">@GetInitial(r.UserName)</div>
                                    <div>
                                        <div class="row-title">@r.UserName</div>
                                        <div class="row-subtitle">@GetTimeRange(r.StartTime, r.EndTime)</div>
                                    </div>
                                </div>
                                <div class="row-meta">@Services.TimerService.FormatDuration(r.DurationSeconds)</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card">
                <h2 class="section-title">今日预约</h2>
                @if (!_status.TodayReservations.Any())
                {
                    <div class="empty-state" style="min-height:100px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px">
                        <span style="font-size:24px;opacity:.4">◫</span>
                        <span>今日暂无预约</span>
                        <span style="font-size:11px;color:var(--text-muted)">可在预约页面创建使用时段</span>
                    </div>
                }
                else
                {
                    <div class="data-list">
                        @foreach (var r in _status.TodayReservations.Take(5))
                        {
                            <div class="data-row">
                                <div class="row-main">
                                    <div class="avatar">@GetInitial(r.UserName)</div>
                                    <span class="row-title">@r.UserName</span>
                                </div>
                                <span class="badge badge-warning">@($"{r.StartHour:D2}:00 - {r.EndHour:D2}:00")</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @* ===== 最近远程会话 ===== *@
        <div class="card" style="margin-bottom:16px">
            <h2 class="section-title">最近远程会话</h2>
            @if (!_remoteSessions.Any())
            { <div class="empty-state">暂无远程会话记录</div> }
            else
            {
                <div class="data-list">
                    @foreach (var s in _remoteSessions.Take(8))
                    {
                        <div class="data-row">
                            <div class="row-main">
                                <div>
                                    <div class="row-title">
                                        @s.RemoteType
                                        @if (IsActiveSession(s))
                                        { <span class="badge badge-danger" style="margin-left:6px">活跃</span> }
                                    </div>
                                    <div class="row-subtitle">
                                        操作人: @(s.OperatorName ?? "未登记") · @s.StartTime
                                        @if (s.EndTime != null) { <span> → @s.EndTime</span> }
                                    </div>
                                </div>
                            </div>
                            <div class="row-meta">@Services.TimerService.FormatDuration(RemoteSessionDuration(s))</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private AppStatus? _status;
    private string _startName = "";
    private string? _startMsg;
    private string _operatorInput = "";
    private string? _operatorMsg;
    private bool _showOperatorModify;
    private List<Monitor.App.Models.RemoteSession> _remoteSessions = new();
    private TunnelStatus _tunnelState = new();
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        _status = StatusService.GetFullStatus();
        _remoteSessions = RemoteSessionRepo.GetRecentRemoteSessions(20);
        _tunnelState = TunnelService.GetStatus();
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                _status = StatusService.GetFullStatus();
                _remoteSessions = RemoteSessionRepo.GetRecentRemoteSessions(20);
                _tunnelState = TunnelService.GetStatus();
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private static (string StatusClass, string LabelColor, string Label, string Tip) GetRemoteDisplay(
        string cs, RemoteControlInfo rc)
    {
        if (rc.Status == "error")
            return ("danger", "var(--danger)", "检测异常", rc.ErrorMessage ?? "检测服务异常，请联系管理员");
        if (rc.Status == "unknown")
            return ("warning", "var(--warning)", "状态未知", rc.ErrorMessage ?? "检测尚未完成或未开启");
        if (rc.IsRemote)
            return ("danger", "var(--danger)", "疑似远程占用", "请勿重复连接，避免控制冲突");
        if (cs == "in_use")
            return ("accent", "var(--accent)", "本机使用中", "当前有本机使用记录，连接前请确认不会打断他人");
        return ("success", "var(--success)", "可连接", "当前未检测到远程占用");
    }

    private static string GetHostText(string url)
    {
        return Uri.TryCreate(url, UriKind.Absolute, out var uri) ? uri.Host : url;
    }

    private static string ShortTunnelError(string error)
    {
        if (string.IsNullOrWhiteSpace(error)) return "检查设置页";
        return error.Contains("cloudflared", StringComparison.OrdinalIgnoreCase)
            ? "检查 cloudflared"
            : "检查设置页";
    }

    private void StartTimer()
    {
        if (TimerService.StartTimer(_startName))
        { _startMsg = "计时已开始"; _startName = ""; _status = StatusService.GetFullStatus(); }
        else { _startMsg = "请输入姓名"; }
    }
    private void HandleStartKeyDown(KeyboardEventArgs args)
    { if (args.Key == "Enter") StartTimer(); }
    private void StopTimer()
    { TimerService.StopTimer(); _startMsg = "计时已停止"; _status = StatusService.GetFullStatus(); }
    private void RegisterOperator()
    {
        if (string.IsNullOrWhiteSpace(_operatorInput)) return;
        if (RemoteMonitorService.TrySetOperatorName(_operatorInput.Trim(), out var error))
        { _operatorMsg = "操作人已登记"; _operatorInput = ""; _showOperatorModify = false; _status = StatusService.GetFullStatus(); }
        else { _operatorMsg = error; }
    }
    private void ShowModifyOperator()
    { _showOperatorModify = true; _operatorInput = _status?.RemoteControl.OperatorName ?? ""; }
    private void CancelModifyOperator()
    { _showOperatorModify = false; _operatorInput = ""; _operatorMsg = ""; }
    private string GetStatusClass(string status) => status switch
    { "error" => "error", "unknown" => "unknown", "remote_controlled" => "remote_controlled", "in_use" => "in_use", _ => "idle" };
    private string GetStatusText(string status) => status switch
    { "error" => "检测异常", "unknown" => "状态未知", "remote_controlled" => "疑似远程占用", "in_use" => "使用中", _ => "空闲" };
    private static bool IsActiveSession(Monitor.App.Models.RemoteSession s) => s.IsActive || string.IsNullOrEmpty(s.EndTime);
    private static int RemoteSessionDuration(Monitor.App.Models.RemoteSession s)
    { if (IsActiveSession(s) && DateTime.TryParse(s.StartTime, out var start)) return (int)(DateTime.Now - start).TotalSeconds; return s.DurationSeconds; }
    private static string GetInitial(string value) => string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString();
    private static string GetTimeRange(string start, string end) => $"{(start.Length >= 16 ? start.Substring(11, 5) : start)} - {(end.Length >= 16 ? end.Substring(11, 5) : end)}";
    public void Dispose() => _timer?.Dispose();
}
