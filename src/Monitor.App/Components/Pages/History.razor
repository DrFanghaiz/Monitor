@page "/history"
@namespace Monitor.App.Components.Pages
@inject TimerService TimerService
@inject IJSRuntime JS

<PageTitle>历史记录 · Monitor</PageTitle>

<div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">历史记录</h1>
            <p class="page-subtitle">查看、搜索和清理使用记录</p>
        </div>
    </header>

    <section class="card toolbar">
        <div class="toolbar-left">
            <label class="field" style="width:130px;">
                <span class="field-label">范围</span>
                <select class="input" @bind="_filterMode" @bind:after="LoadRecords">
                    <option value="all">全部</option>
                    <option value="today">今日</option>
                    <option value="this month">本月</option>
                </select>
            </label>
            <label class="field" style="width:220px;">
                <span class="field-label">搜索</span>
                <input class="input" @bind="_search" @bind:event="oninput" @bind:after="LoadRecords" placeholder="用户名" />
            </label>
        </div>
        <div class="toolbar-right">
            <span class="badge badge-neutral">@_records.Count 条</span>
            @if (_selectedIds.Count > 0)
            {
                <button class="btn btn-danger btn-sm" @onclick="DeleteSelectedAsync">删除选中 @_selectedIds.Count 条</button>
            }
        </div>
    </section>

    <section class="card" style="padding:0;overflow:hidden">
        @if (!_records.Any())
        {
            <div class="empty-state">没有匹配的使用记录</div>
        }
        else
        {
            @* CSS grid table: header + rows use same template *@
            <div class="history-table-header">
                <span></span>
                <span>用户</span>
                <span>时间范围</span>
                <span>时长</span>
                <span>操作</span>
            </div>

            @foreach (var r in _records)
            {
                <div class="history-table-row">
                    <input type="checkbox" checked="@_selectedIds.Contains(r.Id)"
                           @onchange="() => ToggleSelect(r.Id)" aria-label="选择" />
                    <div class="row-main">
                        <div class="avatar">@GetInitial(r.UserName)</div>
                        <span class="row-title">@r.UserName</span>
                    </div>
                    <div>
                        <div class="history-time">@GetTimeRange(r.StartTime, r.EndTime)</div>
                        <div class="duration-track">
                            <div class="duration-fill" style="width:@GetDurationPercent(r.DurationSeconds)"></div>
                        </div>
                    </div>
                    <span class="row-meta" style="margin:0">@TimerService.FormatDuration(r.DurationSeconds)</span>
                    <button class="btn btn-ghost btn-sm critical-action"
                            @onclick="() => DeleteRecordAsync(r.Id, r.UserName)">删除</button>
                </div>
            }
        }
    </section>
</div>

@code {
    private List<UseHistoryItem> _records = new();
    private string _filterMode = "all";
    private string _search = "";
    private HashSet<int> _selectedIds = new();

    protected override void OnInitialized() => LoadRecords();

    private void LoadRecords()
    {
        _records = TimerService.GetHistory(_filterMode, _search);
        _selectedIds.RemoveWhere(id => !_records.Any(r => r.Id == id));
    }

    private void ToggleSelect(int id)
    { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); }

    private async Task DeleteRecordAsync(int id, string userName)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"确定删除 {userName} 的这条使用记录吗？")) return;
        TimerService.DeleteRecord(id); LoadRecords();
    }

    private async Task DeleteSelectedAsync()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"确定删除选中的 {_selectedIds.Count} 条使用记录吗？")) return;
        TimerService.DeleteRecords(_selectedIds.ToList()); _selectedIds.Clear(); LoadRecords();
    }

    private string GetDurationPercent(int seconds)
    {
        var max = Math.Max(_records.Select(r => r.DurationSeconds).DefaultIfEmpty(1).Max(), 1);
        return Math.Clamp(seconds / (double)max * 100, 6, 100).ToString("F0") + "%";
    }
    private static string GetInitial(string value) => string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString();
    private static string GetTimeRange(string start, string end) => $"{FormatTime(start)} - {FormatTime(end)}";
    private static string FormatTime(string value) => value.Length >= 16 ? value.Substring(5, 11) : value;
}
