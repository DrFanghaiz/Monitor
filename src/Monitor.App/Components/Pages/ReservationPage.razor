@page "/reservation"
@namespace Monitor.App.Components.Pages
@inject Services.ReservationService ReservationService
@inject IJSRuntime JS
@using Monitor.App.Models

<PageTitle>预约 · Monitor</PageTitle>

<div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">
                <span class="page-title-icon"><Icon Name="calendar" Size="20" /></span>
                预约管理
            </h1>
            <p class="page-subtitle">安排使用时段，避免时间冲突</p>
        </div>
    </header>

    <section class="reservation-grid">
        <div class="card">
            <h2 class="section-title"><Icon Name="plus" Size="16" />新建预约</h2>
            <div class="form-stack">
                <label class="field">
                    <span class="field-label">使用者</span>
                    <input class="input" @bind="_newName" @bind:event="oninput" placeholder="姓名" />
                </label>
                <label class="field">
                    <span class="field-label">日期</span>
                    <input class="input" type="date" @bind="_newDate" />
                </label>
                <div class="field">
                    <span class="field-label">时段</span>
                    <div class="input-row">
                        <select class="input" @bind="_newStart" aria-label="开始时间">
                            @for (int h = 0; h < 24; h++)
                            {
                                <option value="@h">@($"{h:D2}:00")</option>
                            }
                        </select>
                        <span class="row-subtitle">至</span>
                        <select class="input" @bind="_newEnd" aria-label="结束时间">
                            @for (int h = 1; h <= 24; h++)
                            {
                                <option value="@h">@($"{h:D2}:00")</option>
                            }
                        </select>
                    </div>
                    @if (_newEnd <= _newStart)
                    {
                        <span class="field-hint critical-action">结束时间必须晚于开始时间</span>
                    }
                </div>
                <button class="btn btn-primary" @onclick="CreateReservation" disabled="@(!CanCreate)">
                    <Icon Name="plus" Size="15" />
                    创建预约
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_msg))
            {
                <div class="message">@_msg</div>
            }
        </div>

        <div class="card">
            <div class="toolbar" style="margin-bottom:14px;">
                <h2 class="section-title" style="margin:0;"><Icon Name="calendar" Size="16" />预约列表</h2>
                <input class="input" type="date" @bind="_filterDate" @bind:after="LoadReservations" style="width:170px;" aria-label="筛选日期" />
            </div>

            @if (!_reservations.Any())
            {
                <div class="empty-state">当前日期没有预约</div>
            }
            else
            {
                <div class="data-list">
                    @foreach (var r in _reservations)
                    {
                        <div class="reservation-row">
                            <div class="row-main">
                                <div class="avatar">@GetInitial(r.UserName)</div>
                                <div>
                                    <div class="row-title">@r.UserName</div>
                                    <div class="row-subtitle">@r.Date</div>
                                </div>
                            </div>
                            <div class="toolbar-right">
                                <span class="badge badge-warning">@($"{r.StartHour:D2}:00 - {r.EndHour:D2}:00")</span>
                                <button class="btn btn-ghost btn-sm critical-action" @onclick="() => CancelReservationAsync(r.Id, r.UserName)">
                                    <Icon Name="trash" Size="13" />
                                    取消
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private List<Models.Reservation> _reservations = new();
    private string _newName = "";
    private DateTime _newDate = DateTime.Today;
    private int _newStart = 9;
    private int _newEnd = 10;
    private DateTime? _filterDate;
    private string _msg = "";
    private bool CanCreate => !string.IsNullOrWhiteSpace(_newName) && _newEnd > _newStart;

    protected override void OnInitialized() => LoadReservations();

    private void LoadReservations()
    {
        var dateStr = _filterDate?.ToString("yyyy-MM-dd");
        _reservations = ReservationService.GetReservations(dateStr);
    }

    private void CreateReservation()
    {
        if (!CanCreate)
        {
            _msg = "请填写姓名，并确认结束时间晚于开始时间";
            return;
        }

        var dateStr = _newDate.ToString("yyyy-MM-dd");
        var (success, message, id) = ReservationService.CreateReservation(_newName, dateStr, _newStart, _newEnd);
        _msg = message;
        if (success)
        {
            _newName = "";
            _newStart = 9;
            _newEnd = 10;
            LoadReservations();
        }
    }

    private async Task CancelReservationAsync(int id, string userName)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"确定取消 {userName} 的预约吗？");
        if (!confirmed) return;

        ReservationService.CancelReservation(id);
        LoadReservations();
    }

    private static string GetInitial(string value)
        => string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString();
}
