@page "/settings"
@namespace Monitor.App.Components.Pages
@inject Infrastructure.Config.AppSettings AppSettings
@inject Services.BackupService BackupService
@inject Services.TunnelService TunnelService
@inject Services.WebServerInfo WebServerInfo
@using Monitor.App.Infrastructure.Security

<PageTitle>设置 · Monitor</PageTitle>

<div class="page">
    <header class="page-header">
        <div>
            <h1 class="page-title">
                <span class="page-title-icon"><Icon Name="settings" Size="20" /></span>
                系统设置
            </h1>
            <p class="page-subtitle">密码、备份和本机配置</p>
        </div>
    </header>

    @{
        var setupAlerts = GetSetupAlerts().ToList();
    }
    @if (setupAlerts.Any())
    {
        <div class="setup-alert-stack">
            @foreach (var alert in setupAlerts)
            {
                <div class="setup-alert @alert.Tone">
                    <div class="setup-alert-title">@alert.Title</div>
                    <div class="setup-alert-body">@alert.Body</div>
                </div>
            }
        </div>
    }

    <div class="settings-columns">
        <div class="settings-column">
        @if (_hasDefaultPassword)
        {
            <div class="card" style="border-color:var(--warning);background:var(--warning-soft);">
                <div style="font-size:14px;font-weight:500;color:var(--warning);margin-bottom:4px;">安全提醒</div>
                <div style="font-size:13px;color:var(--text-secondary);">
                    @(_defaultPasswordReasons)
                </div>
            </div>
        }
        <div class="card">
            <h2 class="section-title"><Icon Name="key" Size="16" />管理员密码</h2>
            <div class="form-stack" style="max-width:380px;">
                <label class="field">
                    <span class="field-label">当前密码</span>
                    <input class="input" type="password" @bind="_adminOldPwd" @bind:event="oninput" placeholder="输入当前密码" autocomplete="current-password" />
                </label>
                <label class="field">
                    <span class="field-label">新密码</span>
                    <input class="input" type="password" @bind="_adminNewPwd" @bind:event="oninput" placeholder="输入新密码" autocomplete="new-password" />
                </label>
                <button class="btn btn-primary" @onclick="ChangeAdminPassword" disabled="@(!CanChangeAdminPassword)">
                    <Icon Name="key" Size="15" />
                    确认修改
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_adminMsg))
            {
                <div class="message">@_adminMsg</div>
            }
        </div>

        <div class="card">
            <h2 class="section-title"><Icon Name="key" Size="16" />Web 访问密码</h2>
            <div class="form-stack" style="max-width:380px;">
                <label class="field">
                    <span class="field-label">新密码</span>
                    <input class="input" type="password" @bind="_webPwd" @bind:event="oninput" placeholder="输入 Web 访问密码" autocomplete="new-password" />
                </label>
                <button class="btn btn-primary" @onclick="ChangeWebPassword" disabled="@string.IsNullOrWhiteSpace(_webPwd)">
                    <Icon Name="key" Size="15" />
                    确认修改
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_webMsg))
            {
                <div class="message">@_webMsg</div>
            }
        </div>

        <div class="card">
            <h2 class="section-title"><Icon Name="key" Size="16" />操作人登记码</h2>
            <div class="form-stack" style="max-width:380px;">
                <label class="field">
                    <span class="field-label">
                        当前状态: @(string.IsNullOrEmpty(AppSettings.OperatorRegistrationKey) ? "未配置" : "已配置")
                    </span>
                </label>
                <label class="field">
                    <span class="field-label">新登记码（4 字符以上）</span>
                    <input class="input" @bind="_regKey" @bind:event="oninput" placeholder="设置新登记码" autocomplete="off" />
                </label>
                <button class="btn btn-primary" @onclick="SetRegistrationKey" disabled="@(string.IsNullOrWhiteSpace(_regKey) || _regKey.Trim().Length < 4)">
                    <Icon Name="key" Size="15" />
                    保存
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_regMsg))
            {
                <div class="message">@_regMsg</div>
            }
        </div>
        </div>

        <div class="settings-column">

        <div class="card">
            <div class="toolbar" style="margin-bottom:14px;">
                <h2 class="section-title" style="margin:0;"><Icon Name="database" Size="16" />数据备份</h2>
                <button class="btn btn-ghost" @onclick="CreateBackup">
                    <Icon Name="database" Size="15" />
                    立即备份
                </button>
            </div>

            @if (!_backups.Any())
            {
                <div class="empty-state">暂无备份，建议先创建一次手动备份</div>
            }
            else
            {
                <div class="data-list">
                    @foreach (var b in _backups.Take(6))
                    {
                        <div class="data-row">
                            <div>
                                <div class="row-title">@b.Name</div>
                                <div class="row-subtitle">@(b.IsManual ? "手动备份" : "自动备份")</div>
                            </div>
                            <div class="row-meta">@FormatFileSize(b.Size) · @b.Created</div>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_backupMsg))
            {
                <div class="message">@_backupMsg</div>
            }
        </div>

        <div class="card">
            <h2 class="section-title"><Icon Name="globe" Size="16" />公网发布向导</h2>
            <div class="form-stack" style="max-width:420px;">
                <label class="field">
                    <span class="field-label">固定访问域名</span>
                    <input class="input" @bind="_cloudflareHostname" @bind:event="oninput"
                           placeholder="monitor.fanghaiz.top" autocomplete="off" />
                    <span class="field-hint">请填写已经接入 Cloudflare 的完整子域名。</span>
                </label>
                <div class="toolbar" style="justify-content:flex-start;gap:8px;">
                    <button class="btn btn-ghost" @onclick="StartCloudflareLogin" disabled="@_cloudflareBusy">
                        <Icon Name="external-link" Size="15" />
                        打开 Cloudflare 授权
                    </button>
                    <button class="btn btn-primary" @onclick="ConfigureCloudflare" disabled="@(!CanConfigureCloudflare || _cloudflareBusy)">
                        <Icon Name="globe" Size="15" />
                        一键配置并启动
                    </button>
                </div>
            </div>
            <div class="info-grid" style="margin-top:12px;">
                <span class="info-label">当前域名</span><span>@(string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname) ? "未配置" : AppSettings.CloudflareHostname)</span>
                <span class="info-label">隧道名称</span><span>@AppSettings.CloudflareTunnelName</span>
                <span class="info-label">访问地址</span><span>@(string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname) ? "—" : "https://" + AppSettings.CloudflareHostname + "/status")</span>
            </div>
            @if (!string.IsNullOrEmpty(_cloudflareMsg))
            {
                <div class="message">@_cloudflareMsg</div>
            }
        </div>

        <div class="card">
            <h2 class="section-title"><Icon Name="info" Size="16" />系统信息</h2>
            <div class="info-grid">
                <span class="info-label">数据库</span><span>monitor.db</span>
                <span class="info-label">备份目录</span><span>@AppSettings.BackupPath</span>
                <span class="info-label">自动备份</span><span>@(AppSettings.AutoBackup ? "启用" : "禁用")</span>
                <span class="info-label">备份保留</span><span>@AppSettings.BackupRetentionDays 天</span>
                <span class="info-label">Tunnel</span><span>@AppSettings.TunnelMode</span>
                <span class="info-label">远程检测</span><span>@(AppSettings.RemoteMonitorEnabled ? "启用" : "禁用")</span>
                <span class="info-label">Web 端口</span><span>@AppSettings.WebServerPort</span>
                <span class="info-label">公网隧道</span><span>@GetTunnelStatus()</span>
                @if (!string.IsNullOrEmpty(GetTunnelError()))
                {
                    <span class="info-label"></span><span style="color:var(--danger);font-size:12px;">@GetTunnelError()</span>
                }
                <span class="info-label">主题</span><span>@AppSettings.Theme</span>
            </div>
        </div>
        </div>
    </div>
</div>

@code {
    private string _adminOldPwd = "";
    private string _adminNewPwd = "";
    private string _webPwd = "";
    private string _adminMsg = "";
    private string _webMsg = "";
    private string _backupMsg = "";
    private string _regKey = "";
    private string _regMsg = "";
    private string _cloudflareHostname = "";
    private string _cloudflareMsg = "";
    private bool _cloudflareBusy;
    private bool _hasDefaultPassword;
    private string _defaultPasswordReasons = "";
    private List<BackupEntry> _backups = new();
    private bool CanChangeAdminPassword => !string.IsNullOrWhiteSpace(_adminOldPwd) && !string.IsNullOrWhiteSpace(_adminNewPwd);
    private bool CanConfigureCloudflare
        => Uri.CheckHostName(_cloudflareHostname.Trim()) == UriHostNameType.Dns
           && _cloudflareHostname.Trim().Contains('.');

    protected override void OnInitialized()
    {
        _cloudflareHostname = AppSettings.CloudflareHostname;
        CheckDefaultPasswords();
        LoadBackups();
    }

    private void CheckDefaultPasswords()
    {
        var reasons = new List<string>();
        if (!PasswordManager.IsPasswordSet(AppSettings))
            reasons.Add("管理员密码未设置，正在使用默认密码");
        if (AppSettings.WebServerPassword == "123456")
            reasons.Add("Web 访问密码仍是默认值");
        if (reasons.Count > 0)
        {
            _hasDefaultPassword = true;
            _defaultPasswordReasons = string.Join("；", reasons) + "。建议尽快修改。";
        }
    }

    private void ChangeAdminPassword()
    {
        _adminMsg = PasswordManager.ChangeAdminPassword(AppSettings, _adminOldPwd, _adminNewPwd)
            ? "密码修改成功"
            : "当前密码不正确";
        _adminOldPwd = "";
        _adminNewPwd = "";
    }

    private void ChangeWebPassword()
    {
        AppSettings.WebServerPassword = _webPwd;
        AppSettings.Save();
        _webMsg = "Web 密码已更新";
        _webPwd = "";
    }

    private void CreateBackup()
    {
        var path = BackupService.CreateBackup(manual: true);
        _backupMsg = "备份完成: " + Path.GetFileName(path);
        LoadBackups();
    }

    private void SetRegistrationKey()
    {
        var key = _regKey.Trim();
        if (key.Length < 4) { _regMsg = "登记码长度至少 4 个字符"; return; }
        AppSettings.OperatorRegistrationKey = key;
        AppSettings.Save();
        _regMsg = "登记码已保存";
        _regKey = "";
    }

    private IEnumerable<(string Tone, string Title, string Body)> GetSetupAlerts()
    {
        if (!PasswordManager.IsPasswordSet(AppSettings))
            yield return ("danger", "修改管理员密码", "当前仍是默认密码。");

        if (AppSettings.WebServerPassword == "123456")
            yield return ("warning", "修改 Web 密码", "当前仍是默认密码。");

        if (!AppSettings.RemoteMonitorEnabled)
            yield return ("danger", "打开远程检测", "关闭后无法判断远程占用。");

        if (string.IsNullOrWhiteSpace(AppSettings.OperatorRegistrationKey))
            yield return ("warning", "设置登记码", "用于网页登记操作人。");

        if (string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname))
            yield return ("warning", "配置固定网址", "在公网发布向导中填写域名。");

        var tunnel = TunnelService.GetStatus();
        if (!string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname) && !tunnel.Running)
            yield return ("danger", "固定网址未连接", $"重新执行公网发布：{AppSettings.CloudflareHostname}");

        if (!string.IsNullOrWhiteSpace(tunnel.Error))
            yield return ("danger", "公网发布出错", tunnel.Error);
    }

    private async Task StartCloudflareLogin()
    {
        _cloudflareBusy = true;
        _cloudflareMsg = "正在打开 Cloudflare 授权页面，请在浏览器中完成授权。";
        try
        {
            var result = await TunnelService.StartCloudflareLoginAsync();
            _cloudflareMsg = result.Message;
        }
        finally
        {
            _cloudflareBusy = false;
        }
    }

    private async Task ConfigureCloudflare()
    {
        _cloudflareBusy = true;
        _cloudflareMsg = "正在配置固定域名，请不要关闭软件。";
        try
        {
            var result = await TunnelService.ConfigureCloudflareNamedTunnelAsync(_cloudflareHostname);
            _cloudflareMsg = result.Success && !string.IsNullOrEmpty(result.PublicUrl)
                ? result.Message + " 访问地址：" + result.PublicUrl + "/status"
                : result.Message;
        }
        finally
        {
            _cloudflareBusy = false;
        }
    }

    private string GetTunnelStatus()
    {
        var ts = TunnelService.GetStatus();
        if (!ts.Running && string.IsNullOrEmpty(ts.Error)) return "未开启";
        if (ts.Running && ts.PublicUrl != null) return "已连接 · " + ts.PublicUrl;
        if (ts.Running) return "启动中...";
        return "异常";
    }

    private string GetTunnelError() => TunnelService.GetStatus().Error ?? "";

    private void LoadBackups() => _backups = BackupService.GetBackupList();

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1024 * 1024) return (bytes / 1024.0).ToString("F1") + " KB";
        return (bytes / (1024.0 * 1024.0)).ToString("F1") + " MB";
    }
}
