@page "/settings"
@namespace Monitor.App.Components.Pages
@inject Infrastructure.Config.AppSettings AppSettings
@inject Services.BackupService BackupService
@inject Services.TunnelService TunnelService
@inject Services.WebServerInfo WebServerInfo
@using Monitor.App.Infrastructure.Security
@using Monitor.App.Infrastructure.Config

<PageTitle>设置 · Monitor</PageTitle>

<div class="page settings-page">
    <header class="page-header">
        <div>
            <h1 class="page-title">
                <span class="page-title-icon"><Icon Name="settings" Size="20" /></span>
                系统设置
            </h1>
            <p class="page-subtitle">完成访问、发布和数据维护配置。</p>
        </div>
    </header>

    <section class="settings-readiness">
        <div class="readiness-head">
            <div>
                <h2>准备情况</h2>
                <p>@GetIssueSummary()</p>
            </div>
            <span class="readiness-count @GetIssueTone()">@GetIssueCountText()</span>
        </div>
        <div class="readiness-grid">
            @foreach (var item in GetReadinessItems())
            {
                <div class="readiness-item @item.Tone">
                    <span class="readiness-dot"></span>
                    <div>
                        <strong>@item.Title</strong>
                        <span>@item.Value</span>
                    </div>
                </div>
            }
        </div>
    </section>

    <div class="settings-layout">
        <section class="card settings-access-card">
            <div class="settings-card-head">
                <div>
                    <h2><Icon Name="key" Size="16" />账号与访问</h2>
                    <p>先设置密码和登记码。</p>
                </div>
            </div>

            <div class="settings-section">
                <div class="settings-section-head">
                    <div>
                        <h3>管理员密码</h3>
                        <p>用于本机管理操作。</p>
                    </div>
                    <span class="badge @(PasswordManager.IsPasswordSet(AppSettings) ? "badge-success" : "badge-danger")">
                        @(PasswordManager.IsPasswordSet(AppSettings) ? "已设置" : "默认")
                    </span>
                </div>
                <div class="settings-action-row settings-action-row-three">
                    <label class="field">
                        <span class="field-label">当前密码</span>
                        <input class="input" type="password" @bind="_adminOldPwd" @bind:event="oninput" placeholder="输入当前密码" autocomplete="current-password" />
                    </label>
                    <label class="field">
                        <span class="field-label">新密码</span>
                        <input class="input" type="password" @bind="_adminNewPwd" @bind:event="oninput" placeholder="输入新密码" autocomplete="new-password" />
                    </label>
                    <button class="btn btn-primary" @onclick="ChangeAdminPassword" disabled="@(!CanChangeAdminPassword)">
                        <Icon Name="key" Size="15" />
                        保存
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_adminMsg))
                {
                    <div class="message">@_adminMsg</div>
                }
            </div>

            <div class="settings-section">
                <div class="settings-section-head">
                    <div>
                        <h3>Web 访问密码</h3>
                        <p>用于访问受保护接口。</p>
                    </div>
                    <span class="badge @(AppSettings.WebServerPassword == "123456" ? "badge-warning" : "badge-success")">
                        @(AppSettings.WebServerPassword == "123456" ? "默认" : "已设置")
                    </span>
                </div>
                <div class="settings-action-row">
                    <label class="field">
                        <span class="field-label">新密码</span>
                        <input class="input" type="password" @bind="_webPwd" @bind:event="oninput" placeholder="输入 Web 访问密码" autocomplete="new-password" />
                    </label>
                    <button class="btn btn-primary" @onclick="ChangeWebPassword" disabled="@string.IsNullOrWhiteSpace(_webPwd)">
                        <Icon Name="key" Size="15" />
                        保存
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_webMsg))
                {
                    <div class="message">@_webMsg</div>
                }
            </div>

            <div class="settings-section">
                <div class="settings-section-head">
                    <div>
                        <h3>操作人登记码</h3>
                        <p>远程使用者在网页登记姓名时使用。</p>
                    </div>
                    <span class="badge @(PasswordManager.HasOperatorRegistrationKey(AppSettings) ? "badge-success" : "badge-warning")">
                        @(PasswordManager.HasOperatorRegistrationKey(AppSettings) ? "已设置" : "未设置")
                    </span>
                </div>
                <div class="settings-action-row">
                    <label class="field">
                        <span class="field-label">新登记码</span>
                        <input class="input" @bind="_regKey" @bind:event="oninput" placeholder="至少 8 个字符" autocomplete="off" />
                    </label>
                    <button class="btn btn-primary" @onclick="SetRegistrationKey" disabled="@(string.IsNullOrWhiteSpace(_regKey) || _regKey.Trim().Length < 8)">
                        <Icon Name="key" Size="15" />
                        保存
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_regMsg))
                {
                    <div class="message">@_regMsg</div>
                }
            </div>
        </section>

        <div class="settings-side-stack">
            <section class="card settings-cloud-card">
                <div class="settings-card-head">
                    <div>
                        <h2><Icon Name="globe" Size="16" />公网发布</h2>
                        <p>让别人通过固定网址查看状态。</p>
                    </div>
                    <span class="badge @GetTunnelBadgeClass()">@GetTunnelShortStatus()</span>
                </div>

                <label class="field settings-domain-field">
                    <span class="field-label">固定访问域名</span>
                    <input class="input" @bind="_cloudflareHostname" @bind:event="oninput"
                           placeholder="monitor.fanghaiz.top" autocomplete="off" />
                </label>

                <div class="settings-cloud-actions">
                    <button class="btn btn-ghost" @onclick="StartCloudflareLogin" disabled="@_cloudflareBusy">
                        <Icon Name="external-link" Size="15" />
                        授权
                    </button>
                    <button class="btn btn-primary" @onclick="ConfigureCloudflare" disabled="@(!CanConfigureCloudflare || _cloudflareBusy)">
                        <Icon Name="globe" Size="15" />
                        @(_cloudflareBusy ? "处理中" : "配置并启动")
                    </button>
                </div>

                <div class="settings-detail-grid">
                    <span>当前域名</span><strong>@(string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname) ? "未配置" : AppSettings.CloudflareHostname)</strong>
                    <span>隧道名称</span><strong>@AppSettings.CloudflareTunnelName</strong>
                    <span>访问地址</span><strong>@GetPublicUrlText()</strong>
                </div>

                @if (!string.IsNullOrEmpty(GetTunnelError()))
                {
                    <div class="settings-inline-error">@GetTunnelError()</div>
                }
                @if (!string.IsNullOrEmpty(_cloudflareMsg))
                {
                    <div class="message">@_cloudflareMsg</div>
                }
            </section>

            <section class="card settings-data-card">
                <div class="settings-card-head">
                    <div>
                        <h2><Icon Name="database" Size="16" />数据与系统</h2>
                        <p>备份和本机路径。</p>
                    </div>
                    <button class="btn btn-ghost" @onclick="CreateBackup" disabled="@_backupBusy">
                        <Icon Name="database" Size="15" />
                        @(_backupBusy ? "备份中" : "立即备份")
                    </button>
                </div>

                @if (!_backups.Any())
                {
                    <div class="empty-state">暂无备份。</div>
                }
                else
                {
                    var latestBackup = _backups[0];
                    <div class="settings-backup-summary">
                        <div>
                            <span>最近备份</span>
                            <strong>@latestBackup.Created</strong>
                        </div>
                        <div>
                            <span>类型</span>
                            <strong>@(latestBackup.IsManual ? "手动" : "自动") · @FormatFileSize(latestBackup.Size)</strong>
                        </div>
                        <div>
                            <span>备份数量</span>
                            <strong>@_backups.Count 个</strong>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_backupMsg))
                {
                    <div class="message">@_backupMsg</div>
                }

                <div class="settings-system-grid">
                    <span>数据目录</span><strong>@AppPaths.DataDirectory</strong>
                    <span>备份目录</span><strong>@AppSettings.BackupPath</strong>
                    <span>自动备份</span><strong>@(AppSettings.AutoBackup ? "启用" : "停用")</strong>
                    <span>保留时间</span><strong>@AppSettings.BackupRetentionDays 天</strong>
                    <span>远程检测</span><strong>@(AppSettings.RemoteMonitorEnabled ? "启用" : "停用")</strong>
                    <span>Web 端口</span><strong>@AppSettings.WebServerPort</strong>
                </div>
            </section>
        </div>
    </div>
</div>

@code {
    private string _adminOldPwd = "";
    private string _adminNewPwd = "";
    private string _webPwd = "";
    private string _adminMsg = "";
    private string _webMsg = "";
    private string _backupMsg = "";
    private string _regKey = "";
    private string _regMsg = "";
    private string _cloudflareHostname = "";
    private string _cloudflareMsg = "";
    private bool _cloudflareBusy;
    private bool _backupBusy;
    private List<BackupEntry> _backups = new();
    private bool CanChangeAdminPassword => !string.IsNullOrWhiteSpace(_adminOldPwd) && !string.IsNullOrWhiteSpace(_adminNewPwd);
    private bool CanConfigureCloudflare
        => Uri.CheckHostName(_cloudflareHostname.Trim()) == UriHostNameType.Dns
           && _cloudflareHostname.Trim().Contains('.');

    protected override void OnInitialized()
    {
        _cloudflareHostname = AppSettings.CloudflareHostname;
        LoadBackups();
    }

    private void ChangeAdminPassword()
    {
        _adminMsg = PasswordManager.ChangeAdminPassword(AppSettings, _adminOldPwd, _adminNewPwd)
            ? "已保存。"
            : "当前密码不正确。";
        _adminOldPwd = "";
        _adminNewPwd = "";
    }

    private void ChangeWebPassword()
    {
        AppSettings.WebServerPassword = _webPwd;
        AppSettings.Save();
        _webMsg = "已保存。";
        _webPwd = "";
    }

    private async Task CreateBackup()
    {
        _backupBusy = true;
        _backupMsg = "";
        try
        {
            var path = await Task.Run(() => BackupService.CreateBackup(manual: true));
            _backupMsg = "备份完成: " + Path.GetFileName(path);
            LoadBackups();
        }
        finally
        {
            _backupBusy = false;
        }
    }

    private void SetRegistrationKey()
    {
        var key = _regKey.Trim();
        if (key.Length < 8)
        {
            _regMsg = "至少 8 个字符。";
            return;
        }

        PasswordManager.SetOperatorRegistrationKey(AppSettings, key);
        _regMsg = "已保存。";
        _regKey = "";
    }

    private IReadOnlyList<ReadinessItem> GetReadinessItems()
    {
        var tunnel = TunnelService.GetStatus();
        var publicTone = "warning";
        var publicValue = "未配置";

        if (!string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname))
        {
            publicTone = tunnel.PublicReady ? "ok" : "danger";
            publicValue = tunnel.PublicReady ? "已连接" : "未连接";
        }

        return new List<ReadinessItem>
        {
            new("admin", "管理员密码", PasswordManager.IsPasswordSet(AppSettings) ? "ok" : "danger", PasswordManager.IsPasswordSet(AppSettings) ? "已设置" : "默认"),
            new("web", "Web 密码", AppSettings.WebServerPassword == "123456" ? "warning" : "ok", AppSettings.WebServerPassword == "123456" ? "默认" : "已设置"),
            new("remote", "远程检测", AppSettings.RemoteMonitorEnabled ? "ok" : "danger", AppSettings.RemoteMonitorEnabled ? "启用" : "关闭"),
            new("register", "登记码", PasswordManager.HasOperatorRegistrationKey(AppSettings) ? "ok" : "warning", PasswordManager.HasOperatorRegistrationKey(AppSettings) ? "已设置" : "未设置"),
            new("public", "公网发布", publicTone, publicValue)
        };
    }

    private string GetIssueSummary()
    {
        var count = GetReadinessItems().Count(i => i.Tone != "ok");
        return count == 0 ? "关键配置已完成。" : "先处理未完成项。";
    }

    private string GetIssueCountText()
    {
        var count = GetReadinessItems().Count(i => i.Tone != "ok");
        return count == 0 ? "正常" : $"{count} 项待处理";
    }

    private string GetIssueTone()
    {
        var items = GetReadinessItems();
        if (items.Any(i => i.Tone == "danger")) return "danger";
        if (items.Any(i => i.Tone == "warning")) return "warning";
        return "ok";
    }

    private string GetTunnelShortStatus()
    {
        var ts = TunnelService.GetStatus();
        if (ts.PublicReady) return "已连接";
        if (ts.Running) return "启动中";
        if (!string.IsNullOrEmpty(ts.Error)) return "异常";
        return "未开启";
    }

    private string GetTunnelBadgeClass()
    {
        var ts = TunnelService.GetStatus();
        if (ts.PublicReady) return "badge-success";
        if (ts.Running) return "badge-warning";
        if (!string.IsNullOrEmpty(ts.Error)) return "badge-danger";
        return "badge-neutral";
    }

    private string GetPublicUrlText()
        => string.IsNullOrWhiteSpace(AppSettings.CloudflareHostname)
            ? "未配置"
            : "https://" + AppSettings.CloudflareHostname + "/status";

    private async Task StartCloudflareLogin()
    {
        _cloudflareBusy = true;
        _cloudflareMsg = "请在浏览器完成授权。";
        try
        {
            var result = await TunnelService.StartCloudflareLoginAsync();
            _cloudflareMsg = result.Message;
        }
        finally
        {
            _cloudflareBusy = false;
        }
    }

    private async Task ConfigureCloudflare()
    {
        _cloudflareBusy = true;
        _cloudflareMsg = "正在配置。";
        try
        {
            var result = await TunnelService.ConfigureCloudflareNamedTunnelAsync(_cloudflareHostname);
            _cloudflareMsg = result.Success && !string.IsNullOrEmpty(result.PublicUrl)
                ? "已连接: " + result.PublicUrl + "/status"
                : result.Message;
        }
        finally
        {
            _cloudflareBusy = false;
        }
    }

    private string GetTunnelError() => TunnelService.GetStatus().Error ?? "";

    private void LoadBackups() => _backups = BackupService.GetBackupList();

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1024 * 1024) return (bytes / 1024.0).ToString("F1") + " KB";
        return (bytes / (1024.0 * 1024.0)).ToString("F1") + " MB";
    }

    private sealed record ReadinessItem(string Key, string Title, string Tone, string Value);
}
