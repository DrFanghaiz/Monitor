@page "/timer"
@namespace Monitor.App.Components.Pages
@inject Services.TimerService TimerService
@inject StatusService StatusService
@implements IDisposable

<PageTitle>计时 · Monitor</PageTitle>

<div class="page timer-page">
    <header class="page-header">
        <div>
            <h1 class="page-title">计时</h1>
            <p class="page-subtitle">@(_isRunning ? "会话进行中" : "等待开始")</p>
        </div>
        <span class="status-dot @TimerStatusClass"></span>
    </header>

    <div class="timer-workspace">
        <section class="card card-elevated timer-card-full @(_isRunning ? "timer-card-running" : "")">
            @if (_isRunning)
            {
                <div class="timer-user">@_currentUser</div>
                <div class="timer-display">@_elapsed</div>
                <div class="row-subtitle" style="text-align:center;margin-top:4px">开始于 @_startTime</div>
                <div class="timer-controls" style="margin-top:16px">
                    <button class="btn btn-danger" @onclick="StopTimer">停止计时</button>
                </div>
            }
            else
            {
                <div class="timer-display" style="color:var(--text-muted)">00:00:00</div>
                <div class="row-subtitle" style="text-align:center;margin-top:4px">输入使用者姓名后开始记录</div>
                <div class="timer-entry-row" style="margin-top:16px">
                    <input class="input" @bind="_userName" @bind:event="oninput"
                           @onkeydown="HandleKeyDown" placeholder="使用者姓名" aria-label="使用者姓名" />
                    <button class="btn btn-primary" @onclick="StartTimer"
                            disabled="@string.IsNullOrWhiteSpace(_userName)">开始计时</button>
                </div>
            }
        </section>

        <aside class="card timer-side-panel">
            <section class="timer-info-block">
                <h2 class="section-title">最近一次计时</h2>
                @if (_lastResult != null)
                {
                    <div class="row-title">@_lastResult.UserName</div>
                    <div class="session-value" style="font-size:22px;margin-top:4px">@_lastResult.DurationFormatted</div>
                    <div class="row-subtitle" style="margin-top:2px">上一条记录</div>
                }
                else
                {
                    <div class="empty-state" style="min-height:80px;display:flex;align-items:center;justify-content:center">
                        暂无最近计时，完成一次计时后会显示
                    </div>
                }
            </section>

            <section class="timer-info-block">
                <h2 class="section-title">今日状态</h2>
                <div style="font-size:13px;color:var(--text-secondary)">
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border-light)">
                        <span>当前状态</span>
                        <span>@(_isRunning ? "正在计时" : "空闲")</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border-light)">
                        <span>当前使用者</span>
                        <span>@(_isRunning ? _currentUser : "—")</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:6px 0;">
                        <span>记录查看</span>
                        <span>历史记录页面</span>
                    </div>
                </div>
            </section>
        </aside>
    </div>
</div>

@code {
    private bool _isRunning;
    private string _currentUser = "";
    private string _elapsed = "00:00:00";
    private string _startTime = "";
    private string _userName = "";
    private TimerStopResult? _lastResult;
    private System.Threading.Timer? _timer;
    private string TimerStatusClass => _isRunning ? "in_use" : "idle";

    protected override void OnInitialized() => RefreshState();

    private void RefreshState()
    {
        var state = TimerService.GetState();
        _isRunning = state.IsRunning;
        _currentUser = state.CurrentUser ?? "";
        _elapsed = state.ElapsedFormatted;
        _startTime = state.StartTime ?? "";
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _timer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() => { RefreshState(); StateHasChanged(); });
            }, null, 200, 200);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs args) { if (args.Key == "Enter") StartTimer(); }
    private void StartTimer()
    { if (TimerService.StartTimer(_userName)) { _userName = ""; RefreshState(); } }
    private void StopTimer()
    { _lastResult = TimerService.StopTimer(); RefreshState(); }
    public void Dispose() => _timer?.Dispose();
}
