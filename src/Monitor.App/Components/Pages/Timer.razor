@page "/timer"
@namespace Monitor.App.Components.Pages
@inject Services.TimerService TimerService
@inject StatusService StatusService
@implements IDisposable

<PageTitle>计时 · Monitor</PageTitle>

<div class="page timer-stage">
    <section class="card-elevated timer-card @(_isRunning ? "timer-card-running" : "")">
        <div class="status-line" style="justify-content:center;">
            <Icon Name="timer" Size="18" />
            <span class="status-dot @TimerStatusClass"></span>
            <span class="row-title">@(_isRunning ? "会话进行中" : "等待开始")</span>
        </div>

        @if (_isRunning)
        {
            <div class="timer-user">@_currentUser</div>
            <div class="timer-display">@_elapsed</div>
            <div class="row-subtitle">开始于 @_startTime</div>
            <div class="timer-controls">
                <button class="btn btn-danger" @onclick="StopTimer">
                    <Icon Name="stop" Size="15" />
                    停止计时
                </button>
            </div>
        }
        else
        {
            <div class="timer-display" style="color:var(--text-muted);">00:00:00</div>
            <div class="row-subtitle">输入使用者姓名后开始记录</div>
            <div class="timer-controls">
                <input class="input timer-input" @bind="_userName" @bind:event="oninput" @onkeydown="HandleKeyDown" placeholder="使用者姓名" aria-label="使用者姓名" />
                <button class="btn btn-primary" @onclick="StartTimer" disabled="@string.IsNullOrWhiteSpace(_userName)">
                    <Icon Name="play" Size="15" />
                    开始计时
                </button>
            </div>

            @if (_lastResult != null)
            {
                <div class="last-result">
                    <div class="metric-label">上一次计时</div>
                    <div class="row-title" style="margin-top:8px;">@_lastResult.UserName</div>
                    <div class="session-value" style="font-size:24px;text-align:center;">@_lastResult.DurationFormatted</div>
                </div>
            }
        }
    </section>
</div>

@code {
    private bool _isRunning;
    private string _currentUser = "";
    private string _elapsed = "00:00:00";
    private string _startTime = "";
    private string _userName = "";
    private TimerStopResult? _lastResult;
    private System.Threading.Timer? _timer;
    private string TimerStatusClass => _isRunning ? "in_use" : "idle";

    protected override void OnInitialized()
    {
        RefreshState();
    }

    private void RefreshState()
    {
        var state = TimerService.GetState();
        _isRunning = state.IsRunning;
        _currentUser = state.CurrentUser ?? "";
        _elapsed = state.ElapsedFormatted;
        _startTime = state.StartTime ?? "";
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _timer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    RefreshState();
                    StateHasChanged();
                });
            }, null, 200, 200);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            StartTimer();
        }
    }

    private void StartTimer()
    {
        if (TimerService.StartTimer(_userName))
        {
            _userName = "";
            RefreshState();
        }
    }

    private void StopTimer()
    {
        _lastResult = TimerService.StopTimer();
        RefreshState();
    }

    public void Dispose() => _timer?.Dispose();
}
